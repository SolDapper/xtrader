# Heroku sets PORT automatically — do not set here
# DATABASE_URL is set automatically by Heroku Postgres addon

# App
APP_URL=https://your-app.herokuapp.com
NODE_ENV=production

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Encryption — must be exactly 64 hex chars (32 bytes for AES-256)
# generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Solana RPC
RPC=https://your-rpc-endpoint

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=xTrader Desk <your@gmail.com>
